{
  "name": "instagram-messenger",
  "version": "0.2.0",
  "private": true,
  "description": "Desktop wrapper for Instagram Direct — Linux + Windows",
  "homepage": "https://github.com/adrenal36/instagram-messenger",
  "author": {
    "name": "badwolf",
    "email": "badwolf@users.noreply.github.com"
  },
  "main": "dist-ts/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "dist": "tsc && electron-builder",
    "dist:linux": "tsc && electron-builder --linux",
    "dist:win": "tsc && electron-builder --win",
    "type-check": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@vitest/ui": "^4.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "badwolf.ro.instagram-messenger",
    "productName": "Instagram Messenger",
    "files": [
      "dist-ts/**",
      "package.json",
      "build/icon.png",
      "build/tray-plain.png",
      "build/tray-dot.png"
    ],
    "asarUnpack": [
      "build/*.png"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Network",
      "synopsis": "Desktop wrapper for Instagram Direct",
      "desktop": {
        "entry": {
          "Name": "Instagram Messenger",
          "Categories": "Network;InstantMessaging;Chat;",
          "StartupWMClass": "instagram-messenger"
        }
      }
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "adrenal36",
      "repo": "instagram-messenger",
      "releaseType": "draft"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
